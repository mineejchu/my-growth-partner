# =========================================================
# 나의 성장 파트너 — API 키 설정 파일
# =========================================================
# 이 파일을 복사해서 ".env" 파일을 만들고 키를 채워주세요.
#   cp .env.example .env   (Mac/Linux)
#   copy .env.example .env (Windows)

# ---------------------------------------------------------
# [옵션 A] Anthropic Claude API (추천)
# ---------------------------------------------------------
# 키 발급: https://console.anthropic.com/
# 사용 모델: claude-sonnet-4-6
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------------------------------------------------------
# [옵션 B] OpenAI API
# ---------------------------------------------------------
# 키 발급: https://platform.openai.com/api-keys
# 사용 모델: gpt-4o-mini
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ※ 두 옵션 중 하나만 설정하면 됩니다.
#   우선순위: Anthropic → OpenAI
